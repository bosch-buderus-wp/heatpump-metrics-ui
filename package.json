{
  "name": "heatpump-metrics-ui",
  "version": "1.6.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bosch-buderus-wp/heatpump-metrics-ui.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:prod": "vite build --mode production",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "preview": "vite preview",
    "prepare": "husky",
    "release": "npm run release:tag && npm run release:push",
    "release:tag": "git tag v$(node -p \"require('./package.json').version\")",
    "release:push": "git push origin v$(node -p \"require('./package.json').version\")"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.2",
    "@mui/x-data-grid": "^9.7.0",
    "@nivo/bar": "^0.99.0",
    "@nivo/core": "^0.99.0",
    "@nivo/geo": "^0.99.0",
    "@nivo/scatterplot": "^0.99.0",
    "@supabase/supabase-js": "^2.110.0",
    "@tanstack/react-query": "^5.101.2",
    "dayjs": "^1.11.21",
    "i18next": "^26.3.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "terser": "^5.48.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "rollup": "^4.62.2",
    "yaml": "^2.9.0",
    "cosmiconfig": {
      "yaml": "2.9.0"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --write",
      "bash -c 'tsc --noEmit'",
      "bash -c 'npm test'"
    ],
    "*.json": [
      "biome check --write --files-ignore-unknown=true"
    ]
  }
}
